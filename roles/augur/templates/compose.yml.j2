x-postgres-common:
  &postgres-common
  image: postgres:16
  user: postgres
  restart: unless-stopped
  stop_grace_period: 1800s
  shm_size: 25g  #matches what postgres has set for shared_buffers
  healthcheck:
    test: 'pg_isready -U augur --dbname=postgres'
    interval: 10s
    timeout: 5s
    retries: 5

services:
  database:
    <<: *postgres-common
    environment:
      POSTGRES_DB: ${AUGUR_DB}
      POSTGRES_USER: ${AUGUR_DB_USER}
      POSTGRES_PASSWORD: ${AUGUR_DB_PASSWORD}
    ports:
      - 5432:5432
    volumes:
      - {{ postgres_data_mount_point }}:/var/lib/postgresql/data
     # - /opt/facade/dumps/:/dumps # probably legacy from when backups were done this way
    networks:
      - collectoss
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${AUGUR_DB_USER:-augur} -d ${AUGUR_DB_NAME:-augur}"]
      interval: 10s
      timeout: 5s
      retries: 5

  redis:
    image: redis:alpine
    restart: unless-stopped
    networks:
      - collectoss

  keyman:
    image: ghcr.io/chaoss/collectoss-keyman:{{ augur_tag_version }}
    restart: unless-stopped
    user: 3456:3456  # Run as an arbitrary non-root user
    environment:
      REDIS_CONN_STRING: redis://redis:6379
    depends_on:
      - redis
    networks:
      - collectoss

  rabbitmq:
    image: augur-rabbitmq:{{ augur_tag_version }}
    restart: unless-stopped
    networks:
      - collectoss
    healthcheck:
      test: ["CMD", "rabbitmq-diagnostics", "ping"]
      interval: 10s
      timeout: 5s
      retries: 10
      start_period: 10s

  core:
    image: ghcr.io/chaoss/collectoss:{{ augur_tag_version }}
    volumes:
      - /opt/facade/clones:/collectoss/facade
      - /opt/facade/logs:/logs
      - {{ augur_config_data_mount_point }}:/config
    restart: unless-stopped
    #command:
    #  [ "sleep", "3600" ]
    ports:
      - 5000:5000
    extra_hosts:
      - "host.docker.internal:host-gateway" #Be able to ping services on the local machine
    environment:
      AUGUR_DB: postgresql+psycopg2://${AUGUR_DB_USER:-augur}:${AUGUR_DB_PASSWORD:-augur}@database:5432/augur
      AUGUR_DB_SCHEMA_BUILD: 1
      AUGUR_DOCKER_DEPLOY: 1
      AUGUR_FLAGS: ${AUGUR_FLAGS}
      AUGUR_GITHUB_USERNAME: ${AUGUR_GITHUB_USERNAME}
      AUGUR_GITHUB_API_KEY: ${AUGUR_GITHUB_API_KEY}
      AUGUR_GITLAB_USERNAME: ${AUGUR_GITLAB_USERNAME}
      AUGUR_GITLAB_API_KEY: ${AUGUR_GITLAB_API_KEY}
      REDIS_CONN_STRING: redis://redis:6379
      RABBITMQ_CONN_STRING: amqp://${AUGUR_RABBITMQ_USERNAME:-augur}:${AUGUR_RABBITMQ_PASSWORD:-password123}@rabbitmq:5672/${AUGUR_RABBITMQ_VHOST:-augur_vhost}
      AUGUR_RESET_LOGS: False
      CONFIG_DATADIR: /config
    networks:
      - collectoss
    depends_on:
      database:
        condition: service_healthy
      redis:
        condition: service_started
      keyman:
        condition: service_started
      rabbitmq:
        condition: service_healthy

  flower:
    image: ghcr.io/chaoss/collectoss:{{ augur_tag_version }}
    restart: unless-stopped
    command:
      [ "celery", "-A", "collectoss.tasks.init.celery_app.celery_app", "flower", "--max-tasks=1000000" ]
    environment:
      AUGUR_DB: postgresql+psycopg2://${AUGUR_DB_USER:-augur}:${AUGUR_DB_PASSWORD:-augur}@database:5432/augur
      REDIS_CONN_STRING: redis://redis:6379
      RABBITMQ_CONN_STRING: amqp://${AUGUR_RABBITMQ_USERNAME:-augur}:${AUGUR_RABBITMQ_PASSWORD:-password123}@rabbitmq:5672/${AUGUR_RABBITMQ_VHOST:-augur_vhost}
    ports:
      - 5555:5555
    networks:
      - collectoss
    depends_on:
      - core
      - database
      - redis
      - rabbitmq
  
networks:
  collectoss:
